<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <ApplicationIcon>..\..\ytdlp-icon.ico</ApplicationIcon>
    <AssemblyName>MovieDownloader</AssemblyName>
    <RootNamespace>YtdlGUI.Wpf</RootNamespace>
    <Version>1.0.0</Version>
    <NoWarn>$(NoWarn);WPF0001</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <Resource Include="..\..\ytdlp-icon.ico" Link="ytdlp-icon.ico" />
    <Resource Include="..\..\ytdlp-icon.png" Link="Assets\ytdlp-icon.png" Condition="Exists('..\..\ytdlp-icon.png')" />
    <Content Include="..\..\THIRD_PARTY_NOTICES.md" Link="THIRD_PARTY_NOTICES.md" CopyToPublishDirectory="PreserveNewest" ExcludeFromSingleFile="true" />
    <Content Include="..\..\LICENSE" Link="LICENSE" CopyToPublishDirectory="PreserveNewest" ExcludeFromSingleFile="true" />
    <Content Include="..\..\licenses\DOTNET_RUNTIME_LICENSE.txt" Link="licenses\DOTNET_RUNTIME_LICENSE.txt" CopyToPublishDirectory="PreserveNewest" ExcludeFromSingleFile="true" />
  </ItemGroup>
</Project>
