<Window x:Class="YtdlGUI.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Movie Downloader"
        Width="1180"
        Height="820"
        MinWidth="880"
        MinHeight="680"
        Icon="ytdlp-icon.ico"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </Window.Resources>

    <Grid Background="{DynamicResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="36,30,36,28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="動画のURLを入力してください" Style="{StaticResource SectionLabel}" />
                        <Grid>
                            <TextBox Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="16"
                                     MinHeight="48"
                                     Padding="14,10,48,10"
                                     VerticalContentAlignment="Center"
                                     ToolTip="YouTubeなどの動画URLを入力します" />
                            <Button Content="×"
                                    Command="{Binding ClearUrlCommand}"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Width="36"
                                    Height="34"
                                    Margin="0,0,6,0"
                                    FontSize="18"
                                    ToolTip="URLを消去" />
                        </Grid>
                    </StackPanel>
                    <ProgressBar Grid.Column="1"
                                 Width="42"
                                 Height="4"
                                 Margin="16,52,0,0"
                                 IsIndeterminate="True"
                                 Visibility="{Binding IsInspecting, Converter={StaticResource BoolToVisibility}}" />
                </Grid>

                <Border Grid.Row="1"
                        Style="{StaticResource SurfaceCard}"
                        Margin="0,22,0,0"
                        Visibility="{Binding HasMetadata, Converter={StaticResource BoolToVisibility}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="260" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Width="240" Height="135" CornerRadius="7" ClipToBounds="True" Background="{DynamicResource MutedSurfaceBrush}">
                            <Image Source="{Binding Metadata.ThumbnailUrl}"
                                   Stretch="UniformToFill"
                                   SnapsToDevicePixels="True" />
                        </Border>
                        <StackPanel Grid.Column="1" Margin="24,4,0,0">
                            <TextBlock Text="{Binding Metadata.Title}"
                                       FontFamily="Segoe UI Variable Display, Segoe UI"
                                       FontSize="21"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       MaxHeight="60" />
                            <TextBlock Text="{Binding Metadata.Uploader}"
                                       Style="{StaticResource SecondaryText}"
                                       Margin="0,10,0,0" />
                            <WrapPanel Margin="0,16,0,0">
                                <TextBlock Text="{Binding DurationText, StringFormat=再生時間  {0}}" Style="{StaticResource SecondaryText}" Margin="0,0,24,0" />
                                <TextBlock Text="{Binding ResolutionText, StringFormat=解像度  {0}}" Style="{StaticResource SecondaryText}" Margin="0,0,24,0" />
                                <TextBlock Text="{Binding UploadDateText, StringFormat=公開日  {0}}" Style="{StaticResource SecondaryText}" />
                            </WrapPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="2" Margin="0,24,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="出力形式" Style="{StaticResource SectionLabel}" />
                        <StackPanel Orientation="Horizontal">
                            <RadioButton Content="動画  MP4"
                                         IsChecked="{Binding IsVideoSelected}"
                                         Style="{StaticResource PresetRadio}" />
                            <RadioButton Content="音声  M4A"
                                         IsChecked="{Binding IsM4aSelected}"
                                         Style="{StaticResource PresetRadio}" />
                            <RadioButton Content="音声  MP3"
                                         IsChecked="{Binding IsMp3Selected}"
                                         Style="{StaticResource PresetRadio}" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="16,0,16,0">
                        <TextBlock Text="保存先" Style="{StaticResource SectionLabel}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding OutputDirectory}"
                                     IsReadOnly="True"
                                     MinHeight="48"
                                     Padding="12,9"
                                     VerticalContentAlignment="Center" />
                            <Button Grid.Column="1"
                                    Content="参照…"
                                    Command="{Binding BrowseCommand}"
                                    MinWidth="84"
                                    MinHeight="48"
                                    Margin="8,0,0,0" />
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text=" " Style="{StaticResource SectionLabel}" />
                        <Button Content="ダウンロード"
                                Command="{Binding DownloadCommand}"
                                Style="{StaticResource PrimaryButton}"
                                MinWidth="190" />
                    </StackPanel>
                </Grid>

                <Border Grid.Row="3" Style="{StaticResource SurfaceCard}" Margin="0,26,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding StatusText}" FontWeight="SemiBold" FontSize="15" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding ProgressPercentage, StringFormat={}{0:0}%}"
                                       FontFamily="Segoe UI Variable Display, Segoe UI"
                                       FontSize="24"
                                       FontWeight="SemiBold" />
                        </Grid>
                        <ProgressBar Grid.Row="1"
                                     Value="{Binding ProgressPercentage, Mode=OneWay}"
                                     Minimum="0"
                                     Maximum="100"
                                     Height="5"
                                     Margin="0,12,0,0" />
                        <Grid Grid.Row="2" Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="速度" Style="{StaticResource SecondaryText}" />
                            <TextBlock Grid.Column="1" Text="{Binding Speed}" Margin="8,0,28,0" />
                            <TextBlock Grid.Column="2" Text="{Binding Eta, StringFormat=残り {0}}" />
                            <Button Grid.Column="3"
                                    Content="フォルダを開く"
                                    Command="{Binding OpenFolderCommand}"
                                    Margin="0,0,10,0" />
                            <Button Grid.Column="4"
                                    Content="キャンセル"
                                    Command="{Binding CancelCommand}"
                                    Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVisibility}}" />
                        </Grid>
                    </Grid>
                </Border>

                <StackPanel Grid.Row="4" Margin="0,22,0,0">
                    <Expander Header="詳細設定">
                        <Border Style="{StaticResource SurfaceCard}" Margin="0,8,0,0">
                            <StackPanel>
                                <CheckBox Content="サムネイルを埋め込む"
                                          IsChecked="{Binding EmbedThumbnail}"
                                          Margin="0,0,0,12" />
                                <CheckBox Content="日本語・英語字幕を保存して動画へ埋め込む"
                                          IsChecked="{Binding DownloadSubtitles}"
                                          IsEnabled="{Binding IsVideoSelected}"
                                          Margin="0,0,0,12" />
                                <CheckBox Content="音声をWAVへ変換する"
                                          IsChecked="{Binding ConvertAudioToWav}"
                                          IsEnabled="{Binding IsAudioSelected}"
                                          Margin="0,0,0,16" />
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding VersionText}" Style="{StaticResource SecondaryText}" VerticalAlignment="Center" />
                                    <Button Content="yt-dlpを更新"
                                            Command="{Binding UpdateYtDlpCommand}"
                                            Margin="16,0,0,0" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Expander>
                    <Expander Header="ログ" Margin="0,8,0,0">
                        <Border Style="{StaticResource SurfaceCard}" Margin="0,8,0,0">
                            <ListBox ItemsSource="{Binding LogLines}"
                                     FontFamily="Cascadia Mono, Consolas"
                                     FontSize="12"
                                     MaxHeight="220"
                                     BorderThickness="0"
                                     Background="Transparent" />
                        </Border>
                    </Expander>
                </StackPanel>

                <Border Grid.Row="5"
                        Background="{DynamicResource ErrorSurfaceBrush}"
                        BorderBrush="{DynamicResource ErrorBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="14,10"
                        Margin="0,18,0,0"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{DynamicResource ErrorBrush}"
                               TextWrapping="Wrap" />
                </Border>
            </Grid>
        </ScrollViewer>

        <Border Grid.Row="1"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Background="{DynamicResource FooterBrush}"
                Padding="36,12">
            <Grid>
                <TextBlock Text="{Binding AppVersionText}" Style="{StaticResource SecondaryText}" />
                <TextBlock Text="Windows 11 Fluent · .NET 10"
                           Style="{StaticResource SecondaryText}"
                           HorizontalAlignment="Right" />
            </Grid>
        </Border>
    </Grid>
</Window>
